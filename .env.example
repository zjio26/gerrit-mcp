# Gerrit MCP Configuration
# Copy this file to .env and fill in your values.

# Base URL of your Gerrit instance (no trailing slash)
GERRIT_URL=https://gerrit.example.com

# Gerrit username for HTTP Basic Auth
GERRIT_USERNAME=your-username

# Gerrit HTTP password or API token (from Settings > HTTP Password)
GERRIT_PASSWORD=your-http-password

# Server bind address
HOST=0.0.0.0

# Server bind port
PORT=8000

# Verify SSL certificates (set to false for self-signed certs)
GERRIT_VERIFY_SSL=true

# HTTP request timeout in seconds
GERRIT_TIMEOUT=30

# Enable readonly mode — reject all write/mutation operations (default: false)
MCP_READONLY=false
